# Database
DATABASE_URL=postgresql://fatturino:fatturino@localhost:5432/fatturino

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173

# Auth — Better Auth secret (generate a random string)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email — Resend (for sending invoices)
RESEND_API_KEY=
FROM_EMAIL=noreply@fatturino.app

# SDI — Invoicetronic API (Phase 3)
INVOICETRONIC_API_KEY=
INVOICETRONIC_BASE_URL=https://api.invoicetronic.com
